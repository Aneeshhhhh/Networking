from sklearn.neural_network import MLPClassifier
import numpy as np

# XOR input
x = np.array([
    [0,0],
    [0,1],
    [1,0],
    [1,1]
])

# XOR output
y = np.array([0,1,1,0])

# Backpropagation Neural Network
model = MLPClassifier(
    hidden_layer_sizes=(2,),
    activation='logistic',
    solver='lbfgs',
    max_iter=5000,
    random_state=1
)

# Train model
model.fit(x, y)

# Prediction
pred = model.predict(x)

print("Predicted Output:")
print(pred)